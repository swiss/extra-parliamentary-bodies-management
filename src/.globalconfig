dotnet_diagnostic.CA1056.severity = none # CA1056: URI properties should not be strings
dotnet_diagnostic.CA1707.severity = none # CA1707: Identifiers should not contain underscores
dotnet_diagnostic.CA1724.severity = none # CA1724: Type names should not conflict with namespaces
dotnet_diagnostic.CA1819.severity = none # CA1819: Properties should not return arrays
dotnet_diagnostic.CA1852.severity = none # CA1852: Seal internal types
dotnet_diagnostic.CA1861.severity = none # CA1861: Avoid constant arrays as arguments
dotnet_diagnostic.CA2007.severity = none # CA2007: Do not directly await a Task (enforce ConfigureAwait())
dotnet_diagnostic.CA2234.severity = none # CA2234: Pass system uri objects instead of strings
dotnet_diagnostic.CA1848.severity = none # CA1848: Loger message delegates
dotnet_diagnostic.CA2227.severity = none # CA2227: Collections can not be readonly (needed by EF)
