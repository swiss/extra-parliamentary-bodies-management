{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "Bk.APG.UI": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "apg",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "allowedCommonJsDependencies": [
              "ajv",
              "ajv-formats",
              "froala-editor"
            ],
            "outputPath": "dist/bk.apg.ui",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "node_modules/@oblique/oblique/assets",
                "output": "assets"
              },
              {
                "glob": "*/**",
                "input": "node_modules/@oblique/oblique/styles/fonts",
                "output": "assets/fonts"
              },
              "src/assets"
            ],
            "styles": [
              "node_modules/@oblique/oblique/styles/css/oblique-core.css",
              "src/styles/styles.scss",
              "node_modules/froala-editor/css/froala_editor.pkgd.min.css"
            ],
            "scripts": [
              "node_modules/@oblique/oblique/ob-features.js",
              "src/assets/flite/plugin.min.js",
              "src/assets/lance/plugin.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "3.5mb",
                  "maximumError": "4.0mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "3kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "styles": {
                  "inlineCritical": false
                }
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "Bk.APG.UI:build:production"
            },
            "development": {
              "buildTarget": "Bk.APG.UI:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4453,
            "proxyConfig": "proxy.conf.json",
            "headers": {
              "Content-Security-Policy": "default-src 'none'; script-src 'self'; img-src 'self' data:; form-action 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:9100 https://*.admin.ch; frame-src 'self' https://*.admin.ch; frame-ancestors 'self';"
            }
          }
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "configPath": "tests/jest.config.js",
            "tsConfig": "tsconfig.spec.json",
            "no-cache": [
              "true"
            ],
            "watch": false
          },
          "configurations": {
            "production": {
              "watch": false,
              "verbose": false
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "prefix": "apg",
      "style": "scss",
      "type": "component"
    },
    "@schematics/angular:directive": {
      "prefix": "apg",
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  },
  "cli": {
    "schematicCollections": [
      "@angular-eslint/schematics"
    ],
    "analytics": false
  }
}
